APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=change-me-32-bytes-base64

DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=phpenterpriseblog
DB_USERNAME=root
DB_PASSWORD=root

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=devpass
REDIS_DSN=redis://:devpass@redis:6379/0

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME_MINUTES=120

LOG_CHANNEL=stderr
LOG_LEVEL=info
